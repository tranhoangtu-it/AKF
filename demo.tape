# AKF Terminal Demo
# Run: vhs demo.tape

Output demo.gif

Set FontSize 15
Set Width 860
Set Height 480
Set Theme "Catppuccin Mocha"
Set Padding 15
Set TypingSpeed 40ms
Set Shell zsh

Type "python3 -m akf quickstart"
Enter
Sleep 6s

Type "# One line. Every AI file stamped automatically."
Enter
Sleep 1.5s

Type 'eval "$(python3 -m akf shell-hook)"'
Enter
Sleep 2s
