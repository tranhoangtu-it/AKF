{
  "name": "akf-vscode",
  "displayName": "AKF — Agent Knowledge Format",
  "description": "Syntax highlighting, validation, and hover info for .akf files",
  "version": "0.1.0",
  "publisher": "akf",
  "repository": {
    "type": "git",
    "url": "https://github.com/HMAKT99/AKF"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:akf"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "akf",
        "aliases": [
          "AKF",
          "Agent Knowledge Format"
        ],
        "extensions": [
          ".akf"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "akf",
        "scopeName": "source.akf",
        "path": "./syntaxes/akf.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "akf.validate",
        "title": "AKF: Validate Current File"
      },
      {
        "command": "akf.inspect",
        "title": "AKF: Inspect Claims"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
