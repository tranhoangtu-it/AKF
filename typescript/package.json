{
  "name": "akf-format",
  "version": "1.2.7",
  "description": "AKF — Agent Knowledge Format SDK for TypeScript",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HMAKT99/AKF",
    "directory": "typescript"
  },
  "homepage": "https://akf.dev",
  "bugs": {
    "url": "https://github.com/HMAKT99/AKF/issues"
  },
  "files": [
    "dist/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "akf",
    "trust",
    "metadata",
    "ai",
    "provenance",
    "agent-knowledge-format"
  ],
  "license": "MIT"
}
